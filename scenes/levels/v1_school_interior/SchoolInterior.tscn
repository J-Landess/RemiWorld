; ──────────────────────────────────────────────────────────────
; School Library — Interior
;
; Layout (all positions relative to centre of the 960×660 room):
;   Top-left / right   : bookshelves
;   Centre-back        : Ms. Huffy's desk
;   Back-right         : locker with Daisy's leash
;   Bottom-centre      : exit door to Start Area
;   PlayerSpawn        : just inside the entrance (bottom)
;
; Run SchoolInteriorManager.gd to spawn player + Ms. Huffy
; and wire up the locker & exit interactions.
; ──────────────────────────────────────────────────────────────

[node name="SchoolInterior" type="Node2D"]
script = ExtResource("1_manager")

