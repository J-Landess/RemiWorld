; Sub-resources for the boundary walls.
; Two shapes cover all four walls: one wide (top/bottom) and one tall (left/right).
[sub_resource type="RectangleShape2D" id="RectShape_H"]
size = Vector2(1700, 20)

[sub_resource type="RectangleShape2D" id="RectShape_V"]
size = Vector2(20, 960)

; ──────────────────────────────────────────────────────────────
; Remi's Start Area — Version 1.1
;
; Layout:
;   - Colourful 2D ground (placeholder ColorRects + emoji)
;   - Four invisible boundary walls (player can't walk off-screen)
;   - Marker2D spawn point
;   - Placeholder NPC positions (StartAreaManager replaces them at runtime)
;   - HUD CanvasLayer (populated by StartAreaManager)
; ──────────────────────────────────────────────────────────────

[node name="StartArea" type="Node2D"]
script = ExtResource("1_manager")

; ── BACKGROUND & GROUND ──────────────────────────────────────
[node name="Ground" type="Node2D" parent="."]

[node name="GrassBase" type="ColorRect" parent="Ground"]
position = Vector2(-800, -450)
size = Vector2(1600, 900)
color = Color(0.35, 0.65, 0.25, 1)

[node name="PathStrip" type="ColorRect" parent="Ground"]
position = Vector2(-40, -450)
size = Vector2(80, 900)
color = Color(0.55, 0.45, 0.30, 1)

[node name="SchoolBuilding" type="ColorRect" parent="Ground"]
position = Vector2(-300, -440)
size = Vector2(200, 180)
color = Color(0.85, 0.80, 0.65, 1)

[node name="SchoolLabel" type="Label" parent="Ground"]
position = Vector2(-290, -380)
text = "🏫 School"
theme_override_font_sizes/font_size = 14

[node name="SchoolDoor" type="Label" parent="Ground"]
position = Vector2(-220, -285)
text = "🚪"
theme_override_font_sizes/font_size = 26

