; ──────────────────────────────────────────────────────────────
; HUD - Heads Up Display
; A CanvasLayer sits "above" the game world — UI drawn here is
; always visible regardless of camera position.
; ──────────────────────────────────────────────────────────────

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_hud")

; ── TOP BAR ───────────────────────────────────────────────────
[node name="TopBar" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 1
anchor_right = 1.0
anchor_bottom = 0.0
offset_right = 0.0
offset_bottom = 48.0
grow_horizontal = 2
grow_vertical = 1
theme_override_constants/separation = 16

[node name="PlayerNameLabel" type="Label" parent="TopBar"]
layout_mode = 2
text = "Remi"
theme_override_font_sizes/font_size = 16
vertical_alignment = 1
modulate = Color(1.0, 1.0, 0.7, 1)

[node name="Spacer" type="Control" parent="TopBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="TokenLabel" type="Label" parent="TopBar"]
layout_mode = 2
text = "⭐ 0 VIBE"
theme_override_font_sizes/font_size = 18
vertical_alignment = 1
modulate = Color(1.0, 0.9, 0.2, 1)

[node name="LevelLabel" type="Label" parent="TopBar"]
layout_mode = 2
text = "Lv.1"
theme_override_font_sizes/font_size = 16
vertical_alignment = 1
modulate = Color(0.7, 1.0, 0.7, 1)

[node name="XPBar" type="ProgressBar" parent="TopBar"]
layout_mode = 2
custom_minimum_size = Vector2(100, 20)
value = 0
size_flags_vertical = 4

; ── DIALOGUE BOX (at bottom of screen) ─────────────────────────
