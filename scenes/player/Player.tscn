[gd_scene load_steps=5 format=3 uid="uid://rw_player"]

[ext_resource type="Script" path="res://scripts/player/Player.gd" id="1_player"]
[ext_resource type="Script" path="res://scripts/player/AvatarRenderer.gd" id="2_renderer"]
[ext_resource type="PackedScene" path="res://scenes/effects/CharacterShadow.tscn" id="3_shadow"]

[sub_resource type="CapsuleShape2D" id="CapsuleShape2D_1"]
radius = 10.0
height = 28.0

[sub_resource type="CircleShape2D" id="CircleShape2D_1"]
radius = 40.0

; ──────────────────────────────────────────────────────────────
; Player Scene — CharacterBody2D with live AvatarRenderer
; The AvatarRenderer (Node2D child) draws the character based on
; whatever was set up in the AvatarCreation screen.
; ──────────────────────────────────────────────────────────────

[node name="Player" type="CharacterBody2D"]
collision_layer = 2
collision_mask = 1
script = ExtResource("1_player")

; Physical hitbox — capsule at feet-level
[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
position = Vector2(0, 12)
shape = SubResource("CapsuleShape2D_1")

[node name="CharacterShadow" parent="." instance=ExtResource("3_shadow")]

; The avatar renderer draws the character figure.
; It reads from AvatarManager automatically.
[node name="AvatarRenderer" type="Node2D" parent="."]
position = Vector2(0, 0)
script = ExtResource("2_renderer")

; Top-down camera with smoothing
[node name="Camera2D" type="Camera2D" parent="."]
zoom = Vector2(2.5, 2.5)
position_smoothing_enabled = true
position_smoothing_speed = 8.0

; Interaction zone — detects nearby NPCs when player presses E
[node name="InteractArea" type="Area2D" parent="."]
collision_layer = 0
collision_mask = 4

[node name="InteractCollision" type="CollisionShape2D" parent="InteractArea"]
shape = SubResource("CircleShape2D_1")

; "[E] Talk" prompt shown when near an NPC
[node name="InteractionLabel" type="Label" parent="."]
position = Vector2(-40, -64)
text = "[E] Talk"
theme_override_font_sizes/font_size = 12
modulate = Color(1, 1, 0.5, 1)
visible = false
